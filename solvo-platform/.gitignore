# =============================================================================
# SOLVO — .gitignore
# =============================================================================

# ─── CRITICAL: Environment files — NEVER commit these ─────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# ─── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Next.js Build ─────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ─── Testing ───────────────────────────────────────────────────────────────
coverage/
.nyc_output

# ─── Debug logs ────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS files ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── IDE / Editor ──────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── TypeScript ────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Vercel ────────────────────────────────────────────────────────────────
.vercel

# ─── Sentry ────────────────────────────────────────────────────────────────
.sentryclirc

# ─── Misc ──────────────────────────────────────────────────────────────────
*.log
.cache/
tmp/
temp/